# ═══════════════════════════════════════════════════
# ZigChain Indexer Sync Monitor Bot — Environment
# ═══════════════════════════════════════════════════

# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to interact with the bot
ALLOWED_USER_IDS=123456,789012

# Comma-separated chat IDs where automatic alerts are sent
ALERT_CHAT_IDS= Telegram chat ids

# ZigChain Tendermint/CometBFT RPC endpoint
RPC_URL= rpc url

# ─── PostgreSQL Instances (DSN format) ───────────
PG_DSN_01=postgresql://user:pass@host1:5432/dbname
PG_DSN_02=postgresql://user:pass@host2:5432/dbname
PG_DSN_03=postgresql://user:pass@host3:5432/dbname
# UAT server — optional, leave empty to disable
PG_DSN_04=postgresql://cosmos_indexer_user:password@host:port/cosmos_indexer_prod

# Table containing the block_height column in all PG databases
PG_INDEXER_TABLE=indexer_table

# Optional: shared proxy URL — if set, both ClickHouse clients connect through
# this URL instead of http://<host>:<port>, while keeping their own db/table/creds.
CLICKHOUSE_URLS=

# ─── ClickHouse Instance 01 ─────────────────────
CH_HOST_01=localhost
CH_PORT_01=8123
CH_USER_01=default
CH_PASS_01=
CH_DB_01=default
CH_TABLE_01=indexer_table

# ─── ClickHouse Instance 02 ─────────────────────
CH_HOST_02=localhost
CH_PORT_02=8123
CH_USER_02=default
CH_PASS_02=
CH_DB_02=default
CH_TABLE_02=indexer_table

# ─── Thresholds ─────────────────────────────────
# Number of blocks behind RPC before an alert fires
ALERT_GAP_THRESHOLD=500

# Number of blocks behind RPC before a recovery fires
RECOVERY_GAP_THRESHOLD=100

# Heartbeat loop interval in milliseconds (5 minutes)
HEARTBEAT_INTERVAL_MS=300000

# CPU history sampling interval in milliseconds (10 minutes)
CPU_HISTORY_INTERVAL_MS=600000

# CPU average threshold used for 6h/12h/24h status
CPU_AVG_THRESHOLD=50

# ─── SSH Tunnel for Postgres Archive ────────────
# Set ARCHIVE_SSH_HOST to tunnel PG_DSN_03 through SSH.
# Use this when the Postgres container is bound to 127.0.0.1 on the remote server.
# Leave ARCHIVE_SSH_HOST empty to disable the tunnel (direct TCP connection).
ARCHIVE_SSH_HOST=199.231.166.2
ARCHIVE_SSH_USER=root
ARCHIVE_REMOTE_PORT=5433
ARCHIVE_LOCAL_PORT=15433

# ─── Environment ────────────────────────────────
# Set to "production" for JSON file logging, omit for pretty console
NODE_ENV=development
