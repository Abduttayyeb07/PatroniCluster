{
  "name": "zigchain-bot",
  "version": "1.0.0",
  "description": "ZigChain Indexer Sync Monitor Bot — monitors 5 indexer databases against live ZigChain RPC",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --outDir dist",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "zigchain",
    "telegram",
    "monitor",
    "blockchain",
    "indexer"
  ],
  "license": "MIT",
  "dependencies": {
    "@clickhouse/client": "^1.4.1",
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "postgres": "^3.4.4",
    "ssh2": "^1.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.9",
    "@types/ssh2": "^1.15.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
